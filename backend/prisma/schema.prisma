generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id         String  @id @default(uuid())
  email      String  @unique
  password   String?
  name       String?
  avatar_url String?
  active_tenant_id String?

  // Profile & Enrichment
  app_role          AppRole  @default(user)
  company_name      String?
  company_domain    String?
  linkedin_url      String?
  x_url             String?
  other_social_urls String[] @default([])
  timezone          String?
  locale            String?
  job_role          String?

  // Lead Scoring
  lead_score_current    Float?
  lead_segment          String?
  lead_score_updated_at DateTime?
  scoring_model_version String?

  created_at                DateTime          @default(now())
  updated_at                DateTime          @updatedAt
  oauth_accounts            OAuthAccount[]
  refresh_tokens            RefreshToken[]
  auth_codes                AuthCode[]
  owned_tenants             Tenant[]          @relation("tenant_owner")
  tenant_memberships        TenantMember[]
  active_tenant             Tenant?           @relation("active_tenant", fields: [active_tenant_id], references: [id], onDelete: SetNull)
  created_domains           Domain[]          @relation("domain_creator")
  requested_join_accounts   AccountJoinRequest[] @relation("join_requestor")
  resolved_join_requests    AccountJoinRequest[] @relation("join_resolver")
  created_campaigns         Campaign[]        @relation("campaign_creator")
  created_campaign_versions CampaignVersion[] @relation("campaign_version_creator")
  tenants                   Tenant[]
  analyticsEvents           AnalyticsEvent[]
  leadSignals               LeadSignal[]

  @@index([active_tenant_id])
}

model Tenant {
  id                String            @id @default(uuid())
  slug              String            @unique @default(uuid())
  name              String
  owner_user_id     String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  owner_user        User              @relation("tenant_owner", fields: [owner_user_id], references: [id], onDelete: Cascade)
  members           TenantMember[]
  domains           Domain[]
  join_requests     AccountJoinRequest[]
  capture_sessions  CaptureSession[]
  capture_turns     CaptureTurn[]
  prompt_nodes      PromptNode[]
  semrush_snapshots SemrushSnapshot[]
  generation_runs   GenerationRun[]
  campaigns         Campaign[]
  campaign_versions CampaignVersion[]
  user              User?             @relation(fields: [userId], references: [id])
  userId            String?
  active_users      User[]            @relation("active_tenant")
  analyticsEvents   AnalyticsEvent[]
  leadSignals       LeadSignal[]

  @@index([owner_user_id, created_at(sort: Desc)])
}

model TenantMember {
  id         String   @id @default(uuid())
  tenant_id  String
  user_id    String
  role       String   @default("owner")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
  @@index([user_id, created_at(sort: Desc)])
}

enum DomainScrapeStatus {
  queued
  running
  completed
  failed
}

enum AccountJoinRequestStatus {
  pending
  approved
  rejected
}

model Domain {
  id                String              @id @default(uuid())
  tenant_id         String
  normalized_domain String
  display_domain    String
  source_url        String
  scrape_status     DomainScrapeStatus  @default(queued)
  last_scraped_at   DateTime?
  created_by_user_id String
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  tenant            Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by_user   User                @relation("domain_creator", fields: [created_by_user_id], references: [id], onDelete: Cascade)
  context           DomainContext?
  scrape_runs       DomainScrapeRun[]
  campaigns         Campaign[]

  @@unique([tenant_id, normalized_domain])
  @@index([tenant_id, created_at(sort: Desc)])
}

model DomainContext {
  id           String   @id @default(uuid())
  domain_id    String   @unique
  context_json Json
  pages_json   Json
  extracted_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  domain       Domain   @relation(fields: [domain_id], references: [id], onDelete: Cascade)

  @@index([extracted_at(sort: Desc)])
}

model DomainScrapeRun {
  id           String             @id @default(uuid())
  domain_id    String
  status       DomainScrapeStatus @default(queued)
  started_at   DateTime           @default(now())
  finished_at  DateTime?
  error_message String?
  page_count   Int?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  domain       Domain             @relation(fields: [domain_id], references: [id], onDelete: Cascade)

  @@index([domain_id, started_at(sort: Desc)])
}

model AccountJoinRequest {
  id                 String                    @id @default(uuid())
  tenant_id          String
  requestor_user_id  String
  status             AccountJoinRequestStatus  @default(pending)
  requested_at       DateTime                  @default(now())
  resolved_at        DateTime?
  resolved_by_user_id String?
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt
  tenant             Tenant                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  requestor_user     User                      @relation("join_requestor", fields: [requestor_user_id], references: [id], onDelete: Cascade)
  resolved_by_user   User?                     @relation("join_resolver", fields: [resolved_by_user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, status, requested_at(sort: Desc)])
  @@index([requestor_user_id, requested_at(sort: Desc)])
}

enum AuthCodeStatus {
  active
  used
  expired
}

enum CaptureStatus {
  listening
  intercepting
  analyzing
  generating
  complete
  failed
}

enum RunStatus {
  queued
  processing
  completed
  failed
}

enum AiChatProvider {
  chatgpt
  claude
  gemini
  perplexity
  grok
  unknown
}

enum NodeType {
  prompt
  subquery
  site
  generated
}

enum CampaignVersionStatus {
  draft
  active
  archived
}

enum AppRole {
  admin
  user
}

model OAuthAccount {
  id                  String   @id @default(uuid())
  user_id             String
  provider            String
  provider_account_id String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, revoked_at])
}

model AuthCode {
  id           String         @id @default(uuid())
  user_id      String
  code_hash    String         @unique
  redirect_uri String
  state        String?
  status       AuthCodeStatus @default(active)
  expires_at   DateTime
  used_at      DateTime?
  created_at   DateTime       @default(now())
  user         User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
}

model Campaign {
  id                 String            @id @default(uuid())
  tenant_id          String
  domain_id          String?
  created_by_user_id String
  name               String
  description        String?
  metadata           Json?
  target_location    String?
  industry_tag       String?
  business_type      String?
  primary_goal       String?
  archived_at        DateTime?
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  tenant             Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  domain             Domain?           @relation(fields: [domain_id], references: [id], onDelete: SetNull)
  created_by_user    User              @relation("campaign_creator", fields: [created_by_user_id], references: [id], onDelete: Cascade)
  versions           CampaignVersion[]
  analyticsEvents    AnalyticsEvent[]

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, archived_at, created_at(sort: Desc)])
  @@index([tenant_id, domain_id, created_at(sort: Desc)])
}

model CampaignVersion {
  id                  String                @id @default(uuid())
  tenant_id           String
  campaign_id         String
  created_by_user_id  String
  version_number      Int
  label               String?
  status              CampaignVersionStatus @default(draft)
  is_active           Boolean               @default(false)
  config_json         Json?
  archive_storage_uri String?
  archived_at         DateTime?
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt
  tenant              Tenant                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  campaign            Campaign              @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  created_by_user     User                  @relation("campaign_version_creator", fields: [created_by_user_id], references: [id], onDelete: Cascade)
  capture_sessions    CaptureSession[]
  prompt_nodes        PromptNode[]
  semrush_snapshots   SemrushSnapshot[]
  generation_runs     GenerationRun[]
  leadSignals         LeadSignal[]

  @@unique([campaign_id, version_number])
  @@index([tenant_id, campaign_id, created_at(sort: Desc)])
  @@index([tenant_id, is_active, created_at(sort: Desc)])
}

model CaptureSession {
  id                  String          @id @default(uuid())
  tenant_id           String
  campaign_version_id String
  chat_provider       AiChatProvider  @default(unknown)
  conversation_id     String
  provider_chat_id    String?
  chat_url            String?
  chat_title          String?
  status              CaptureStatus   @default(listening)
  started_at          DateTime        @default(now())
  last_event_at       DateTime?
  last_opened_at      DateTime?
  metadata            Json?
  tenant              Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  campaign_version    CampaignVersion @relation(fields: [campaign_version_id], references: [id], onDelete: Cascade)
  turns               CaptureTurn[]
  prompt_nodes        PromptNode[]

  @@unique([tenant_id, campaign_version_id, chat_provider, conversation_id], name: "idx_capture_session_unique")
  @@index([tenant_id, campaign_version_id, chat_provider, started_at(sort: Desc)], map: "idx_cs_started_at")
  @@index([tenant_id, campaign_version_id, last_event_at(sort: Desc)], map: "idx_cs_last_event_at")
  @@index([tenant_id, campaign_version_id, chat_provider, provider_chat_id], map: "idx_cs_provider_chat_id")
  @@index([tenant_id, campaign_version_id, chat_provider, chat_url], map: "idx_cs_chat_url")
}

model CaptureTurn {
  id                   String          @id @default(uuid())
  tenant_id            String
  capture_session_id   String
  request_id           String?
  turn_exchange_id     String?
  prompt               String
  finished_reason      String?
  raw_event_json       Json?
  metadata             Json?
  prompt_detected_at   DateTime?
  response_finished_at DateTime?
  created_at           DateTime        @default(now())
  tenant               Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  capture_session      CaptureSession  @relation(fields: [capture_session_id], references: [id], onDelete: Cascade)
  prompt_nodes         PromptNode[]
  generation_runs      GenerationRun[]
  leadSignals          LeadSignal[]

  @@unique([capture_session_id, request_id, turn_exchange_id])
  @@index([tenant_id, capture_session_id, response_finished_at(sort: Desc)])
}

model PromptNode {
  id                  String            @id @default(uuid())
  tenant_id           String
  campaign_version_id String
  capture_session_id  String?
  capture_turn_id     String?
  parent_id           String?
  type                NodeType
  content             String
  metadata            Json?
  depth               Int               @default(0)
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  tenant              Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  campaign_version    CampaignVersion   @relation(fields: [campaign_version_id], references: [id], onDelete: Cascade)
  capture_session     CaptureSession?   @relation(fields: [capture_session_id], references: [id], onDelete: SetNull)
  capture_turn        CaptureTurn?      @relation(fields: [capture_turn_id], references: [id], onDelete: SetNull)
  parent              PromptNode?       @relation("PromptNodeToPromptNode", fields: [parent_id], references: [id], onDelete: SetNull)
  children            PromptNode[]      @relation("PromptNodeToPromptNode")
  semrush_snapshots   SemrushSnapshot[]

  @@index([tenant_id, campaign_version_id, created_at(sort: Desc)])
  @@index([tenant_id, capture_session_id, created_at(sort: Desc)])
  @@index([capture_turn_id])
}

model SemrushSnapshot {
  id                  String          @id @default(uuid())
  tenant_id           String
  campaign_version_id String
  prompt_node_id      String?
  query_text          String
  summary_metrics     Json?
  raw_response        Json?
  fetched_at          DateTime        @default(now())
  tenant              Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  campaign_version    CampaignVersion @relation(fields: [campaign_version_id], references: [id], onDelete: Cascade)
  prompt_node         PromptNode?     @relation(fields: [prompt_node_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, campaign_version_id, fetched_at(sort: Desc)])
}

model GenerationRun {
  id                  String          @id @default(uuid())
  tenant_id           String
  campaign_version_id String
  capture_turn_id     String?
  status              RunStatus       @default(queued)
  depth_limit         Int             @default(3)
  node_limit          Int             @default(200)
  started_at          DateTime?
  finished_at         DateTime?
  error_message       String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  tenant              Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  campaign_version    CampaignVersion @relation(fields: [campaign_version_id], references: [id], onDelete: Cascade)
  capture_turn        CaptureTurn?    @relation(fields: [capture_turn_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, status, created_at(sort: Desc)])
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  tenant_id   String
  user_id     String
  campaign_id String?
  session_id  String?
  event_name  String
  properties  Json
  created_at  DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, event_name, created_at(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
}

model LeadSignal {
  id                  String   @id @default(uuid())
  tenant_id           String
  campaign_version_id String?
  user_id             String
  signal_type         String
  value               Json?
  confidence          Float?
  source_turn_id      String?
  created_at          DateTime @default(now())

  tenant           Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  campaign_version CampaignVersion? @relation(fields: [campaign_version_id], references: [id], onDelete: SetNull)
  capture_turn     CaptureTurn?     @relation(fields: [source_turn_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, user_id, signal_type, created_at(sort: Desc)])
  @@index([tenant_id, campaign_version_id, created_at(sort: Desc)])
}
